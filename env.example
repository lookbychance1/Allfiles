# Admin microservice example environment variables
# ====== Required: core services ======
MONGO_URI=mongodb://mongo-user:password@mongo-host:27017/solvemcq
REDIS_URL=redis://:password@redis-host:6379

# Admin server
ADMIN_PORT=4000
ADMIN_ALLOWED_ORIGINS=https://managemcq.sharepremium.in
ADMIN_JWT_SECRET=replace_with_strong_random_secret
ADMIN_JWT_REFRESH_SECRET=replace_with_another_strong_secret
ADMIN_BOOTSTRAP_SECRET=replace_with_bootstrap_secret
TOTP_ENCRYPT_KEY=replace_with_totp_encrypt_key

# Signing (optional)
ADMIN_SIGN_SECRET=replace_with_signing_secret

# DevTool protection
DEVTOOL_BLOCK_THRESHOLD=3
DEVTOOL_BLOCK_TTL=3600

# Logging and paths
ADMIN_LOG_FILE=./logs/admin-access.log
QUESTION_IMG_DIR=./uploads/questions

# Push notifications (optional)
VAPID_PUBLIC_KEY=put_public_vapid_here
VAPID_PRIVATE_KEY=put_private_vapid_here

# SMTP (optional, for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password
ADMIN_EMAIL=admin@example.com

# External services used by the main app (set to same values as main app to read users/stats)
MAIN_MONGO_URI=${MONGO_URI}
MAIN_REDIS_URL=${REDIS_URL}

# Deployment variables (optional)
DEPLOY_USER=ubuntu
DEPLOY_HOST=managemcq.sharepremium.in
DEPLOY_REPO=git@github.com:your-org/solvemcq-admin.git

# For production, ensure these files are not committed to git and keep secrets in a secret manager
